#!/usr/bin/env sh

# Auto-bump patch version before every commit
node -e "
const fs = require('fs');
const path = require('path');

// Read VERSION file
const versionPath = path.join(process.cwd(), 'app/VERSION');
let version = fs.readFileSync(versionPath, 'utf-8').trim();

// Parse and bump patch
const parts = version.split('.');
parts[2] = parseInt(parts[2], 10) + 1;
const newVersion = parts.join('.');

// Write VERSION
fs.writeFileSync(versionPath, newVersion);

// Update package.json
const pkgPath = path.join(process.cwd(), 'app/package.json');
const pkg = JSON.parse(fs.readFileSync(pkgPath, 'utf-8'));
pkg.version = newVersion;
fs.writeFileSync(pkgPath, JSON.stringify(pkg, null, 2) + '\n');

console.log('Auto-bumped version:', version, '→', newVersion);
"

# Stage the version files
git add app/VERSION app/package.json
